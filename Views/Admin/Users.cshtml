@model IEnumerable<EquipmentRental.Models.ApplicationUser>

<h2>Users</h2>
@if(TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}
<table class="table">
    <thead>
        <tr>
            <th>UserName</th>
            <th>Email</th>
            <th>First/Last</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    @foreach(var u in Model)
    {
        <tr>
            <td>@u.UserName</td>
            <td>@u.Email</td>
            <td>@u.FirstName @u.LastName</td>
            <td>
                <a asp-action="EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-primary">Edit</a>
                <form asp-action="DeleteUser" method="post" style="display:inline-block">
                    <input type="hidden" name="id" value="@u.Id" />
                    <button class="btn btn-sm btn-danger">Delete</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>