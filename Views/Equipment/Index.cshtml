@model IEnumerable<EquipmentRental.Models.EquipmentItem>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Equipment</h2>
    <form class="d-flex" method="get" asp-action="Index">
        <input class="form-control me-2" type="search" placeholder="Search" name="q" />
        <button class="btn btn-outline-secondary" type="submit">Search</button>
    </form>
</div>

<div class="row">
@foreach(var item in Model)
{
    <div class="col-md-4 mb-4">
        <div class="card h-100 shadow-sm">
            <div style="height:220px;overflow:hidden;border-bottom:1px solid rgba(0,0,0,0.03);">
                <img src="@item.ImageUrl" class="card-img-top" style="width:100%;height:100%;object-fit:cover;" />
            </div>
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">@item.Name</h5>
                <p class="card-text text-muted">@item.Condition</p>
                <p class="card-text">@item.Description</p>
                <div class="mt-auto">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <small class="text-muted" style="color:var(--muted-800);">Available: @item.AvailableQuantity</small>
                        <span class="badge" style="background:var(--primary-600);color:white;">@item.Condition</span>
                    </div>

                    @if (User?.IsInRole("Administrator") == true)
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    }
                    else
                    {
                        if (User?.Identity?.IsAuthenticated ?? false)
                        {
                            <form asp-controller="RentalRequests" asp-action="Create" method="get" class="d-inline">
                                <input type="hidden" name="itemId" value="@item.Id" />
                                <button class="btn btn-primary btn-sm">Request</button>
                            </form>
                        }
                        else
                        {
                            <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-sm">Request</a>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
}
</div>

@if (User?.IsInRole("Administrator") == true)
{
    <a asp-action="Create" class="btn btn-primary">Add Equipment</a>
}

@section Scripts{
    <partial name="_ValidationScriptsPartial" />
}